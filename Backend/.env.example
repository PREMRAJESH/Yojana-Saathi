# YojanaSaathi backend — environment variable NAMES only (no real values).
# Copy to .env for local development. In production, set these as platform env vars.

# --- Core app ---
ENVIRONMENT=development            # development | production
DEBUG=false

# --- CORS: explicit comma-separated allowlist. NEVER use "*". ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Rate limiting ---
RATE_LIMIT=20/minute
# Optional: set to a redis:// URL to use Redis as the rate-limit store.
# Leave unset to use in-memory storage (fine for a single instance / local dev).
REDIS_URL=

# --- LLM (Gemini) — OPTIONAL. The system runs fully without it (falls back to
# deterministic text). Provide a key to enable language polish. ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=8
LLM_ENABLED=true

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_JSON=true

# --- Request state cache (request_id -> profile) for /api/draft ---
REQUEST_CACHE_TTL_SECONDS=1800
REQUEST_CACHE_MAX_SIZE=1000
